{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Proton VS Code Extension",
      "type": "extensionHost",
      "request": "launch",
      "preLaunchTask": "build-proton-extension",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/vscode-extension",
        "${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/vscode-extension/**/*.js"
      ]
    }
  ]
}
