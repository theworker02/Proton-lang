{
  "name": "proton-language-support",
  "displayName": "Proton Language Support",
  "description": "VS Code support for Proton, including syntax highlighting, file icons, hover information, and live-buffer diagnostics.",
  "version": "1.5.5",
  "publisher": "magnificent-language",
  "author": "magnificent-language",
  "license": "MIT",
  "icon": "images/Proton.png",
  "homepage": "https://github.com/theworker02/Proton-lang",
  "repository": {
    "type": "git",
    "url": "https://github.com/theworker02/Proton-lang.git"
  },
  "bugs": {
    "url": "https://github.com/theworker02/Proton-lang/issues"
  },
  "keywords": [
    "proton",
    "language",
    "compiler",
    "systems",
    "syntax-highlighting",
    "file-icons"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Themes"
  ],
  "activationEvents": [
    "onLanguage:proton"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "proton",
        "aliases": [
          "Proton",
          "proton"
        ],
        "extensions": [
          ".ptn"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "proton",
        "scopeName": "source.proton",
        "path": "./syntaxes/proton.tmLanguage.json"
      }
    ],
    "iconThemes": [
      {
        "id": "proton-file-icons",
        "label": "Proton File Icons",
        "path": "./icons/proton-icon-theme.json"
      }
    ]
  }
}
