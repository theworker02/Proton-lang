{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "backend/**/*.ts",
    "compiler/**/*.ts",
    "cli/**/*.ts",
    "tests/**/*.ts",
    "vscode-extension/**/*.ts"
  ]
}
